{
  "git": {
    "requireCleanWorkingDir": false,
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": false,
    "releaseName": "v${version} - ${date}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["node ./scripts/verify.mjs"],
    "after:bump": ["node ./scripts/bump.mjs ${version}", "node ./scripts/build.mjs"]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "writerOpts": {
        "headerPartial": "[compare changes](https://github.com/duhnunes/scs-schema/compare/{{previousTag}}...{{currentTag}})"
      },
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "features"
          },
          {
            "type": "fix",
            "section": "Bug Fixes"
          },
          {
            "type": "refactor",
            "section": "Refactors"
          },
          {
            "type": "perf",
            "section": "Performance Improvements"
          },
          {
            "type": "revert",
            "section": "Reverts"
          }
        ]
      }
    }
  }
}
